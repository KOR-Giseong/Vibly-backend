generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
  KAKAO
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum PlaceCategory {
  CAFE
  RESTAURANT
  BAR
  PARK
  CULTURAL
  BOOKSTORE
  BOWLING
  KARAOKE
  SPA
  ESCAPE
  ARCADE
  ETC
}

enum SubscriptionPlatform {
  IOS
  ANDROID
  WEB
}

enum EventType {
  SEARCH
  CLICK_PLACE
  NAVIGATION
  CHECKIN
  BOOKMARK
  SUBSCRIPTION
}

enum NotificationType {
  RECOMMEND
  LIKE
  NEARBY
  PROMO
  REPORT
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  email             String?    @unique
  name              String
  nickname          String?    @unique
  avatarUrl         String?
  gender            String?    // 'MALE' | 'FEMALE' | 'OTHER'
  preferredVibes    String[]
  isProfileComplete Boolean    @default(false)
  provider          AuthProvider
  providerId        String?
  passwordHash      String?
  status            UserStatus @default(ACTIVE)
  isAdmin           Boolean    @default(false)
  suspendedUntil    DateTime?
  suspendReason     String?
  deletedAt         DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  devices         Device[]
  sessions        RefreshToken[]
  bookmarks       Bookmark[]
  checkIns        CheckIn[]
  reviews         Review[]
  notifications   Notification[]
  subscriptions   Subscription[]
  events          UserEvent[]
  vibeReports     VibeReport[]
  supportTickets  SupportTicket[]
  posts           Post[]
  postComments    PostComment[]
  postLikes       PostLike[]
  postReports     PostReport[]

  @@index([email])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketType {
  FAQ
  CHAT
}

model SupportTicket {
  id          String       @id @default(uuid())
  userId      String
  type        TicketType   @default(CHAT)
  title       String
  body        String
  status      TicketStatus @default(OPEN)
  adminReply  String?
  repliedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@index([userId])
  @@index([status])
  @@index([type])
}

model ChatMessage {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String   // userId or 'admin'
  isAdmin   Boolean  @default(false)
  body      String
  imageUrl  String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Device {
  id        String   @id @default(uuid())
  userId    String
  fcmToken  String   @unique
  platform  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ─── Place ───────────────────────────────────────────────────────────────────

model Place {
  id          String        @id @default(uuid())
  name        String
  category    PlaceCategory
  description String?
  address     String
  lat         Float
  lng         Float
  phone       String?
  hours       String?
  rating      Float         @default(0)
  reviewCount Int           @default(0)
  vibeScore   Float         @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tags        PlaceTag[]
  images      PlaceImage[]
  checkIns    CheckIn[]
  bookmarks   Bookmark[]
  reviews     Review[]
  ads         PartnerAd[]
  moodResults MoodSearchPlace[]

  @@index([lat, lng])
  @@index([category])
}

model PlaceTag {
  id      String @id @default(uuid())
  placeId String
  tag     String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model PlaceImage {
  id        String   @id @default(uuid())
  placeId   String
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

// ─── CheckIn & Review ────────────────────────────────────────────────────────

model CheckIn {
  id        String   @id @default(uuid())
  userId    String
  placeId   String
  mood      String
  note      String?
  imageUrl  String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([placeId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  placeId   String
  rating    Int
  body      String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  placeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

// ─── AI / Mood Engine ────────────────────────────────────────────────────────

model MoodSearch {
  id        String   @id @default(uuid())
  userId    String?
  query     String
  mood      String
  summary   String?
  createdAt DateTime @default(now())

  results MoodSearchPlace[]

  @@index([userId])
}

model MoodSearchPlace {
  id             String @id @default(uuid())
  moodSearchId   String
  placeId        String
  relevanceScore Float

  moodSearch MoodSearch @relation(fields: [moodSearchId], references: [id], onDelete: Cascade)
  place      Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model PromptTemplate {
  id        String   @id @default(uuid())
  type      String   @unique
  template  String
  updatedAt DateTime @updatedAt
}

// ─── Subscription & Monetization ─────────────────────────────────────────────

model Subscription {
  id          String               @id @default(uuid())
  userId      String
  platform    SubscriptionPlatform
  receiptData String
  productId   String
  expiresAt   DateTime
  createdAt   DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PartnerAd {
  id        String   @id @default(uuid())
  placeId   String
  region    String
  priority  Int      @default(0)
  imageUrl  String?
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  place  Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  clicks AdClick[]

  @@index([region, isActive])
}

model AdClick {
  id        String   @id @default(uuid())
  adId      String
  userId    String?
  createdAt DateTime @default(now())

  ad PartnerAd @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
}

// ─── Analytics & Events ──────────────────────────────────────────────────────

model UserEvent {
  id        String    @id @default(uuid())
  userId    String?
  type      EventType
  payload   Json?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  payload   Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─── Vibe Report ─────────────────────────────────────────────────────────────

model VibeReport {
  id        String   @id @default(uuid())
  userId    String
  period    String
  summary   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
}

// ─── Deleted Account Cooldown ─────────────────────────────────────────────────

model DeletedAccount {
  id         String       @id @default(uuid())
  provider   AuthProvider
  providerId String?
  email      String?
  deletedAt  DateTime     @default(now())
  canRejoinAt DateTime    // deletedAt + 30일

  @@index([email])
  @@index([provider, providerId])
}

// ─── Community ────────────────────────────────────────────────────────────────

enum PostCategory {
  FREE      // 자유게시판
  INFO      // 정보공유
  QUESTION  // 질문/도움
  REVIEW    // 장소후기
}

model Post {
  id        String       @id @default(uuid())
  userId    String
  category  PostCategory @default(FREE)
  title     String
  body      String
  imageUrl  String?
  isPinned  Boolean      @default(false)
  isHidden  Boolean      @default(false)
  viewCount Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments PostComment[]
  likes    PostLike[]
  reports  PostReport[]

  @@index([category])
  @@index([userId])
  @@index([createdAt])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  body      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model PostLike {
  id     String @id @default(uuid())
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ─── PostReport ───────────────────────────────────────────────────────────────

enum ReportReason {
  SPAM        // 스팸/광고
  ABUSE       // 욕설/혐오
  ILLEGAL     // 불법 정보
  ADULT       // 성인/음란물
  PRIVACY     // 개인정보 침해
  OTHER       // 기타
}

model PostReport {
  id        String       @id @default(uuid())
  postId    String
  userId    String
  reason    ReportReason @default(OTHER)
  detail    String?
  isResolved Boolean     @default(false)
  createdAt DateTime     @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([isResolved])
}

// ─── Notice ───────────────────────────────────────────────────────────────────

model Notice {
  id        String   @id @default(uuid())
  title     String
  body      String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
