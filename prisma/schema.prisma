generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
  KAKAO
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum PlaceCategory {
  CAFE
  RESTAURANT
  BAR
  PARK
  CULTURAL
  BOOKSTORE
  BOWLING
  KARAOKE
  SPA
  ESCAPE
  ARCADE
  ETC
}

enum SubscriptionPlatform {
  IOS
  ANDROID
  WEB
}

enum SubscriptionType {
  MONTHLY
  YEARLY
  TRIAL
  ADMIN_GRANT
}

enum EventType {
  SEARCH
  CLICK_PLACE
  NAVIGATION
  CHECKIN
  BOOKMARK
  SUBSCRIPTION
}

enum CreditTxType {
  SIGNUP_BONUS       // +100 가입 보너스
  MOOD_SEARCH_BASIC  // -5  빠른 검색 (quick match)
  MOOD_SEARCH_AI     // -10 AI 분석 검색 (Gemini)
  CHECKIN_GPS        // +15 GPS 체크인 보상
  CHECKIN_RECEIPT    // +20 영수증 체크인 보상
  AD_WATCH           // +15 광고 시청 보상
  ADMIN_GRANT        // 관리자 지급
  COUPLE_DATE_AI     // -15 커플 AI 데이트 분석
  COUPLE_CREDIT_SEND // 파트너에게 크레딧 전송
}

enum NotificationType {
  RECOMMEND
  LIKE
  NEARBY
  PROMO
  REPORT
  COUPLE_INVITE
  COUPLE_ACCEPT
  COMMENT      // 컴유니티 댓글
  CREDIT       // 크레딧 지급
  SUPPORT      // 지원 답변
}

enum CoupleStatus {
  ACTIVE
  DISSOLVED
}

enum MessageType {
  TEXT
  IMAGE
  EMOJI
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum DatePlanStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  email             String?    @unique
  name              String
  nickname          String?    @unique
  avatarUrl         String?
  gender            String?    // 'MALE' | 'FEMALE' | 'OTHER'
  preferredVibes    String[]
  isProfileComplete Boolean    @default(false)
  provider          AuthProvider
  providerId        String?
  passwordHash      String?
  status            UserStatus @default(ACTIVE)
  isAdmin           Boolean    @default(false)
  suspendedUntil    DateTime?
  suspendReason     String?
  deletedAt         DateTime?
  credits           Int        @default(100)  // 가입 시 100 크레딧 지급
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  devices            Device[]
  sessions           RefreshToken[]
  bookmarks          Bookmark[]
  checkIns           CheckIn[]
  reviews            Review[]
  notifications      Notification[]
  subscriptions      Subscription[]
  events             UserEvent[]
  vibeReports        VibeReport[]
  supportTickets     SupportTicket[]
  posts              Post[]
  postComments       PostComment[]
  postLikes          PostLike[]
  postReports        PostReport[]
  creditTransactions  CreditTransaction[]
  adWatchLogs         AdWatchLog[]
  couplesAsUser1      Couple[]            @relation("CoupleUser1")
  couplesAsUser2      Couple[]            @relation("CoupleUser2")
  sentInvitations     CoupleInvitation[]  @relation("SentInvitations")
  receivedInvitations CoupleInvitation[]  @relation("ReceivedInvitations")
  sentUserReports     UserReport[]        @relation("SentUserReports")
  receivedUserReports UserReport[]        @relation("ReceivedUserReports")

  @@index([email])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketType {
  FAQ
  CHAT
}

model SupportTicket {
  id          String       @id @default(uuid())
  userId      String
  type        TicketType   @default(CHAT)
  title       String
  body        String
  status      TicketStatus @default(OPEN)
  adminReply  String?
  repliedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@index([userId])
  @@index([status])
  @@index([type])
}

model ChatMessage {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String   // userId or 'admin'
  isAdmin   Boolean  @default(false)
  body      String
  imageUrl  String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  pushToken  String   @unique
  platform   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ─── Place ───────────────────────────────────────────────────────────────────

model Place {
  id          String        @id @default(uuid())
  name        String
  category    PlaceCategory
  description String?
  address     String
  lat         Float
  lng         Float
  phone       String?
  hours       String?
  rating      Float         @default(0)
  reviewCount Int           @default(0)
  vibeScore   Float         @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tags        PlaceTag[]
  images      PlaceImage[]
  checkIns    CheckIn[]
  bookmarks   Bookmark[]
  reviews     Review[]
  ads         PartnerAd[]
  moodResults MoodSearchPlace[]

  @@index([lat, lng])
  @@index([category])
}

model PlaceTag {
  id      String @id @default(uuid())
  placeId String
  tag     String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

model PlaceImage {
  id        String   @id @default(uuid())
  placeId   String
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

// ─── CheckIn & Review ────────────────────────────────────────────────────────

model CheckIn {
  id               String   @id @default(uuid())
  userId           String
  placeId          String
  mood             String
  note             String?
  imageUrl         String?
  receiptVerified  Boolean  @default(false)
  receiptHash      String?  // SHA256 of receipt image (영수증 재사용 방지)
  createdAt        DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([placeId])
  @@index([receiptHash])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  placeId   String
  rating    Int
  body      String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  placeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

// ─── AI / Mood Engine ────────────────────────────────────────────────────────

model MoodSearch {
  id        String   @id @default(uuid())
  userId    String?
  query     String
  mood      String
  summary   String?
  createdAt DateTime @default(now())

  results MoodSearchPlace[]

  @@index([userId])
}

model MoodSearchPlace {
  id             String @id @default(uuid())
  moodSearchId   String
  placeId        String
  relevanceScore Float

  moodSearch MoodSearch @relation(fields: [moodSearchId], references: [id], onDelete: Cascade)
  place      Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model PromptTemplate {
  id        String   @id @default(uuid())
  type      String   @unique
  template  String
  updatedAt DateTime @updatedAt
}

// ─── Credit System ───────────────────────────────────────────────────────────

model CreditTransaction {
  id          String        @id @default(uuid())
  userId      String
  amount      Int           // 양수=획득, 음수=소모
  type        CreditTxType
  referenceId String?       // 관련 체크인 ID 등
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model AdWatchLog {
  id        String   @id @default(uuid())
  userId    String
  date      String   // YYYY-MM-DD (KST 기준 날짜)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ─── Subscription & Monetization ─────────────────────────────────────────────

model Subscription {
  id          String               @id @default(uuid())
  userId      String
  platform    SubscriptionPlatform
  type        SubscriptionType     @default(MONTHLY)
  receiptData String               @default("")
  productId   String               @default("")
  expiresAt   DateTime
  createdAt   DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, expiresAt])
}

model PartnerAd {
  id        String   @id @default(uuid())
  placeId   String
  region    String
  priority  Int      @default(0)
  imageUrl  String?
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  place  Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  clicks AdClick[]

  @@index([region, isActive])
}

model AdClick {
  id        String   @id @default(uuid())
  adId      String
  userId    String?
  createdAt DateTime @default(now())

  ad PartnerAd @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
}

// ─── Analytics & Events ──────────────────────────────────────────────────────

model UserEvent {
  id        String    @id @default(uuid())
  userId    String?
  type      EventType
  payload   Json?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  payload   Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─── Vibe Report ─────────────────────────────────────────────────────────────

model VibeReport {
  id        String   @id @default(uuid())
  userId    String
  period    String
  summary   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
}

// ─── Deleted Account Cooldown ─────────────────────────────────────────────────

model DeletedAccount {
  id         String       @id @default(uuid())
  provider   AuthProvider
  providerId String?
  email      String?
  deletedAt  DateTime     @default(now())
  canRejoinAt DateTime    // deletedAt + 30일

  @@index([email])
  @@index([provider, providerId])
}

// ─── Community ────────────────────────────────────────────────────────────────

enum PostCategory {
  FREE      // 자유게시판
  INFO      // 정보공유
  QUESTION  // 질문/도움
  REVIEW    // 장소후기
}

model Post {
  id        String       @id @default(uuid())
  userId    String
  category  PostCategory @default(FREE)
  title     String
  body      String
  imageUrl  String?
  isPinned  Boolean      @default(false)
  isHidden  Boolean      @default(false)
  viewCount Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments PostComment[]
  likes    PostLike[]
  reports  PostReport[]

  @@index([category])
  @@index([userId])
  @@index([createdAt])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  body      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model PostLike {
  id     String @id @default(uuid())
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ─── PostReport ───────────────────────────────────────────────────────────────

enum ReportReason {
  SPAM        // 스팸/광고
  ABUSE       // 욕설/혐오
  HARASSMENT  // 성희롱/괴롭힘
  ILLEGAL     // 불법 정보
  ADULT       // 성인/음란물
  PRIVACY     // 개인정보 침해
  OTHER       // 기타
}

model PostReport {
  id        String       @id @default(uuid())
  postId    String
  userId    String
  reason    ReportReason @default(OTHER)
  detail    String?
  isResolved Boolean     @default(false)
  createdAt DateTime     @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([isResolved])
}

// ─── UserReport ───────────────────────────────────────────────────────────────

model UserReport {
  id         String       @id @default(uuid())
  reporterId String
  reportedId String
  reason     ReportReason @default(OTHER)
  detail     String?
  isResolved Boolean      @default(false)
  createdAt  DateTime     @default(now())

  reporter User @relation("SentUserReports",     fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("ReceivedUserReports",  fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId])
  @@index([reporterId])
  @@index([isResolved])
}

// ─── Couple Lounge ────────────────────────────────────────────────────────────

model Couple {
  id                 String       @id @default(uuid())
  user1Id            String       @unique
  user2Id            String       @unique
  status             CoupleStatus @default(ACTIVE)
  creditShareEnabled Boolean      @default(false)
  anniversaryDate    DateTime?
  dissolvedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user1     User            @relation("CoupleUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User            @relation("CoupleUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  datePlans DatePlan[]
  memories  CoupleMemory[]
  messages  CoupleMessage[]

  @@index([status])
}

model CoupleInvitation {
  id          String           @id @default(uuid())
  senderId    String
  receiverId  String
  status      InvitationStatus @default(PENDING)
  message     String?
  respondedAt DateTime?
  createdAt   DateTime         @default(now())

  sender   User @relation("SentInvitations",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedInvitations", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId])
}

model DatePlan {
  id        String         @id @default(uuid())
  coupleId  String
  title     String
  dateAt    DateTime
  memo      String?
  status    DatePlanStatus @default(PLANNED)
  placeIds  String[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  couple Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
  @@index([coupleId, dateAt])
}

model CoupleMemory {
  id         String    @id @default(uuid())
  coupleId   String
  uploaderId String
  imageUrl   String
  caption    String?
  takenAt    DateTime?
  createdAt  DateTime  @default(now())

  couple Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
  @@index([coupleId, createdAt])
}

model CoupleMessage {
  id        String      @id @default(uuid())
  coupleId  String
  senderId  String
  type      MessageType @default(TEXT)
  text      String?
  imageUrl  String?
  emoji     String?
  readAt    DateTime?
  createdAt DateTime    @default(now())

  couple Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId, createdAt])
}

// ─── App Config (관리자 설정 key-value) ──────────────────────────────────────────

model AppConfig {
  key       String   @id  // FREE_TRIAL_ENABLED, FREE_TRIAL_DAYS, DISCOUNT_ENABLED, DISCOUNT_PCT
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Place Review Summary (AI 요약 캐시) ─────────────────────────────────────────

model PlaceReviewSummary {
  placeId        String   @id
  summary        String
  pros           String[]
  cons           String[]
  targetAudience String?
  reviewCount    Int
  generatedAt    DateTime @default(now())
}

// ─── Notice ───────────────────────────────────────────────────────────────────

model Notice {
  id        String   @id @default(uuid())
  title     String
  body      String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
